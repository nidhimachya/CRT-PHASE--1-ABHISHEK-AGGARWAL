    newNode->next = head;
    head = newNode;
}
void insertAtTail(int data) {
    node* newNode = new node(data);
    node* temp = head;
    while(temp-> next!= nullptr) {
        temp = temp-> next;
    }
        temp-> next =newNode;
    
}

void insertAtPosition(int data, int position) {
    node* newNode = new node(data);
    node* temp = head;
    for(int i = 1; i < position - 1; i++){
        temp = temp->next;
    }
    newNode->next = temp->next;
    temp->next = newNode;
}


//main logic

void display(){
    node*temp = head;
    while(temp != nullptr){
        cout<<temp->data<<" ";
        temp= temp->next;
    }
    cout<<"null ";

}

