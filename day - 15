#include<iostream>
#include <stack>
using namespace std;
int main()
{
    int arr[] = { 10,20,30,40,50};
    int n = 5;
    
    stack<int> st;
    //Java -- Stack<Integer> st = new Stack<>();
    
    //Push the data into Stack
    
    for(int i = 0; i < n; i++){
        st.push(arr[i]);
    }
    //pop data from stack and put into array
    
    for(int i = 0; i < n; i++){
        arr[i] = st.top();
        st.pop();
    }
    
    cout << "Reversed Array...";
    
    for(int i = 0; i < n; i++){
        cout << arr[i] <<" ";
    }
    return 0;
}
