//Problem -- 1 if-else statement
#include <iostream>
using namespace std;

int main(){
    int age;
    cin >> age;
    
    if (age >= 18){
        cout << "Eligible for vote...";
    } else {
        cout << "Not eligible for vote...";
    }
    return 0;
}
