#include <iostream>
using namespace std;

int main(){
    int n;
    cout << " Enter a size of array...";
    cin >> n;
    
    int arr[n];
    
    cout << "Enter the sorted array...";
    for(int i = 0; i < n; i++) {
        cin >> arr[i];
    }
    int target;
    cout << " Enter the target element...";
    cin >> target;
    
    //binary search code
    int low = 0;
    int high = n -1;
    bool found = false;
    
    
    while(low <= high){
        int mid = (low + high) / 2;
        
        if(arr[mid] == target) {
            cout << "Element found at index"<< mid;
            found = true;
            break;
        }else if (arr[mid] < target) {
            low = mid + 1;
            
        }else{
            high = mid - 1;
        }
}

if (found == false){
    cout << "Element not found...";
}
return 0;
}


