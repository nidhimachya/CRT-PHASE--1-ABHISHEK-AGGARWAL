// Problem 5
//Print factorial of a numbers
#include <iostream>
using namespace std;

int main() {
   int n;
   cin >> n;
   int fact = 1;
   
   for(int i = n; i >= 1; i--){
       fact = fact * i;
   }
   cout << fact;
  
   
   }
