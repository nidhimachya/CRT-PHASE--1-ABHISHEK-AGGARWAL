//problem--1 
//making of 2D array

#include <iostream>
using namespace std;

int main(){
    int arr[2][2];
    
    for(int i = 0; i <2; i++){
        for(int j = 0; j <2; j++){
            cin >> arr[i][j];
        }
    }
    
    cout <<"here is your 2 Day array"<<"\n";
    for(int i = 0; i < 2; i++) {
        for(int j = 0; j < 2; j++) {
            cout << arr[i][j] << " ";
        }
        cout << "\n";
    }
    return 0;
}



//problem-- 2
//sum of elements of 2D array

#include <iostream>
using namespace std;

int main(){
    int arr[2][2];
    int sum = 0;
    
    for(int i = 0; i <2; i++){
        for(int j = 0; j <2; j++){
            cin >> arr[i][j];
            sum = sum + arr[i][j];
        }
    }
    
    cout << sum;
}
